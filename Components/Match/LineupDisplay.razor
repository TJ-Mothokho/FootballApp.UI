@if (Lineup != null && Lineup.Any())
{
    var homeStarters = Lineup.Where(p => p.Team == "Home" && p.IsStarter).ToList();
    var homeSubs     = Lineup.Where(p => p.Team == "Home" && !p.IsStarter).ToList();
    var awayStarters = Lineup.Where(p => p.Team == "Away" && p.IsStarter).ToList();
    var awaySubs     = Lineup.Where(p => p.Team == "Away" && !p.IsStarter).ToList();

    var homeRows     = GetFormationRows(homeStarters);
    var awayRows     = GetFormationRows(awayStarters);
    var homeFormation = DeriveFormation(homeStarters);
    var awayFormation = DeriveFormation(awayStarters);

    <div class="lineup-pitch-wrapper">

        <!-- Formation header -->
        <div class="lineup-pitch-header">
            <div class="lineup-pitch-team-info">
                <span class="lineup-pitch-team-name home-color">@HomeTeamName</span>
                <span class="lineup-formation-tag home-tag">@homeFormation</span>
            </div>
            <span class="lineup-pitch-vs">Formation</span>
            <div class="lineup-pitch-team-info align-right">
                <span class="lineup-formation-tag away-tag">@awayFormation</span>
                <span class="lineup-pitch-team-name away-color">@AwayTeamName</span>
            </div>
        </div>

        <!-- ── Football pitch ───────────────────────────────────── -->
        <div class="pitch">

            <!-- Home team: GK at top, attackers toward centre -->
            <div class="pitch-half home-half">
                <div class="pitch-team-label home-label">Home</div>
                @foreach (var row in homeRows)
                {
                    <div class="pitch-row">
                        @foreach (var p in row)
                        {
                            <PitchPlayerCard Player="p" TeamClass="home" />
                        }
                    </div>
                }
            </div>

            <!-- Halfway line & centre circle -->
            <div class="pitch-halfway">
                <div class="pitch-center-spot"></div>
                <div class="pitch-center-circle"></div>
            </div>

            <!-- Away team: attackers toward centre, GK at bottom -->
            <div class="pitch-half away-half">
                <div class="pitch-team-label away-label">Away</div>
                @foreach (var row in awayRows)
                {
                    <div class="pitch-row">
                        @foreach (var p in row)
                        {
                            <PitchPlayerCard Player="p" TeamClass="away" />
                        }
                    </div>
                }
            </div>

        </div>

        <!-- ── Bench ─────────────────────────────────────────────── -->
        <div class="lineup-bench-container">
            <div class="lineup-bench-team">
                <div class="bench-label">🪑 @HomeTeamName — Bench</div>
                @foreach (var p in homeSubs)
                {
                    <div class="bench-player-item">
                        <span class="lineup-number">@p.Number</span>
                        <span class="lineup-name">@p.Name</span>
                        <span class="lineup-pos">@p.Position</span>
                    </div>
                }
                @if (!homeSubs.Any())
                {
                    <div style="color:var(--text-muted);font-size:0.8rem;">No substitutes listed</div>
                }
            </div>
            <div class="lineup-bench-team">
                <div class="bench-label">🪑 @AwayTeamName — Bench</div>
                @foreach (var p in awaySubs)
                {
                    <div class="bench-player-item">
                        <span class="lineup-number">@p.Number</span>
                        <span class="lineup-name">@p.Name</span>
                        <span class="lineup-pos">@p.Position</span>
                    </div>
                }
                @if (!awaySubs.Any())
                {
                    <div style="color:var(--text-muted);font-size:0.8rem;">No substitutes listed</div>
                }
            </div>
        </div>

    </div>
}
else
{
    <div class="empty-state">
        <div class="empty-state-icon">📋</div>
        <div class="empty-state-title">Lineups not available yet</div>
    </div>
}

@code {
    [Parameter] public List<LineupPlayer>? Lineup { get; set; }
    [Parameter] public string HomeTeamName { get; set; } = "Home";
    [Parameter] public string AwayTeamName { get; set; } = "Away";

    // ── Position → row order ───────────────────────────────────────────────
    private static int PositionOrder(string pos) => pos.ToUpperInvariant() switch
    {
        "GK"                         => 0,
        "RB" or "LB" or "CB"
            or "DF" or "RWB" or "LWB" => 1,
        "CDM" or "DM"                => 2,
        "CM" or "MF"                 => 3,
        "LW" or "RW" or "AM"
            or "CAM" or "SS"         => 4,
        "ST" or "CF" or "FW"        => 5,
        // Unrecognised positions fall back to central midfield row
        _                            => 3
    };

    private static List<List<LineupPlayer>> GetFormationRows(List<LineupPlayer> players)
    {
        var groups = players
            .GroupBy(p => PositionOrder(p.Position))
            .OrderBy(g => g.Key)
            .ToList();

        return groups.Select(g => g.ToList()).ToList();
    }

    private static string DeriveFormation(List<LineupPlayer> starters)
    {
        var rows = GetFormationRows(starters);
        // Skip the GK row (order 0)
        var counts = rows
            .Where(r => PositionOrder(r[0].Position) > 0)
            .Select(r => r.Count.ToString());
        return string.Join("-", counts);
    }
}
