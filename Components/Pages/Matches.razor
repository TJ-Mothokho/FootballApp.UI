@page "/matches"
@rendermode InteractiveServer
@inject IFootballDataService DataService

<PageTitle>Matches – FootballSA</PageTitle>

<div class="page-header">
    <div class="container">
        <h1 class="page-header-title">⚽ Matches</h1>
        <p class="page-header-subtitle">All PSL and NFD fixtures and results</p>
    </div>
</div>

<div class="container-wide">
    <div class="filter-pills">
        <button class="filter-pill @(_leagueFilter == null ? "active" : "")" @onclick='() => SetFilter(null)'>All Leagues</button>
        <button class="filter-pill @(_leagueFilter == "PSL" ? "active" : "")" @onclick='() => SetFilter("PSL")'>🏆 PSL</button>
        <button class="filter-pill @(_leagueFilter == "NFD" ? "active" : "")" @onclick='() => SetFilter("NFD")'>🥈 NFD</button>
        <button class="filter-pill @(_statusFilter == "Live" ? "active" : "")" @onclick='() => SetStatus("Live")'>🔴 Live</button>
        <button class="filter-pill @(_statusFilter == "Upcoming" ? "active" : "")" @onclick='() => SetStatus("Upcoming")'>🕐 Upcoming</button>
        <button class="filter-pill @(_statusFilter == "Finished" ? "active" : "")" @onclick='() => SetStatus("Finished")'>✅ Results</button>
    </div>

    @if (_loading)
    {
        <div class="loading-spinner"><div class="spinner"></div><span>Loading...</span></div>
    }
    else
    {
        @foreach (var group in _groupedMatches)
        {
            <div class="section-header mb-2">
                <h3 class="section-title" style="font-size:1rem;">📅 @group.Key</h3>
            </div>
            <div class="grid-auto mb-3">
                @foreach (var m in group.Value)
                {
                    <MatchCard Match="m" />
                }
            </div>
        }
        @if (!_groupedMatches.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">📅</div>
                <div class="empty-state-title">No matches found</div>
            </div>
        }
    }
</div>

@code {
    private bool _loading = true;
    private string? _leagueFilter;
    private string? _statusFilter;
    private List<Match> _matches = new();
    private Dictionary<string, List<Match>> _groupedMatches = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMatches();
    }

    private async Task SetFilter(string? league)
    {
        _leagueFilter = league;
        _statusFilter = null;
        await LoadMatches();
    }

    private async Task SetStatus(string status)
    {
        _statusFilter = _statusFilter == status ? null : status;
        await LoadMatches();
    }

    private async Task LoadMatches()
    {
        _loading = true;
        _matches = await DataService.GetMatchesAsync(league: _leagueFilter, status: _statusFilter);
        _groupedMatches = _matches
            .OrderByDescending(m => m.KickoffTime)
            .GroupBy(m => m.KickoffTime.ToString("dddd, dd MMMM yyyy"))
            .ToDictionary(g => g.Key, g => g.ToList());
        _loading = false;
    }
}
