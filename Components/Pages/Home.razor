@page "/"
@rendermode InteractiveServer
@inject IFootballDataService DataService
@inject IHeroService HeroService

<PageTitle>FootballSA – South African Football</PageTitle>

@if (_loading)
{
    <div class="loading-spinner"><div class="spinner"></div><span>Loading...</span></div>
}
else
{
    @if (_heroContent != null)
    {
        @if (_heroContent.Type == "Match" && _heroContent.Match != null)
        {
            <MatchHeroComponent MatchItem="_heroContent.Match" />
        }
        else if (_heroContent.Type == "News" && _heroContent.News != null)
        {
            <NewsHeroComponent News="_heroContent.News" />
        }
    }

    <div class="container-wide">
        <div class="section">
            <div class="section-header">
                <h2 class="section-title">📅 Today's <span class="title-accent">Fixtures</span></h2>
                <NavLink href="/matches" class="section-link">All matches →</NavLink>
            </div>
            @if (_upcomingMatches.Any())
            {
                <div class="grid-auto">
                    @foreach (var m in _upcomingMatches.Take(6))
                    {
                        <MatchCard Match="m" />
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-state-icon">📅</div>
                    <div class="empty-state-title">No upcoming matches</div>
                </div>
            }
        </div>

        <div class="grid-main-sidebar section">
            <div>
                <div class="section-header">
                    <h2 class="section-title">📰 Latest <span class="title-accent">News</span></h2>
                    <NavLink href="/news" class="section-link">All news →</NavLink>
                </div>
                @if (_news.Any())
                {
                    <div class="mb-2">
                        <NewsCard Article="_news[0]" Hero="true" />
                    </div>
                    <div class="grid-2">
                        @foreach (var article in _news.Skip(1).Take(2))
                        {
                            <NewsCard Article="article" />
                        }
                    </div>
                }
            </div>

            <div>
                <div class="section-header">
                    <h2 class="section-title">🏆 <span class="title-accent">PSL</span> Table</h2>
                    <NavLink href="/league/PSL" class="section-link">Full →</NavLink>
                </div>
                <div class="card p-0">
                    <table class="standings-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Team</th>
                                <th>P</th>
                                <th>Pts</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _pslStandings.Take(6))
                            {
                                <tr>
                                    <td><span style="font-weight:700;color:var(--text-muted);">@s.Position</span></td>
                                    <td class="team-cell">
                                        <div class="team-cell-inner">
                                            <img src="@s.TeamLogo" class="team-cell-logo" alt="@s.TeamName" />
                                            <span class="team-cell-name" style="font-size:0.8rem;">@s.TeamName</span>
                                        </div>
                                    </td>
                                    <td>@s.Played</td>
                                    <td class="points-cell">@s.Points</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="section-header mt-3">
                    <h2 class="section-title">⚽ Top <span class="title-accent">Scorers</span></h2>
                </div>
                <div class="card p-0">
                    @foreach (var (player, i) in _topScorers.Select((p, i) => (p, i + 1)).Take(5))
                    {
                        <PlayerCard Player="player" Rank="i" ShowRank="true" />
                    }
                </div>
            </div>
        </div>

        <div class="section">
            <div class="section-header">
                <h2 class="section-title">🏁 Recent <span class="title-accent">Results</span></h2>
                <NavLink href="/matches" class="section-link">All →</NavLink>
            </div>
            <div class="grid-auto">
                @foreach (var m in _recentMatches.Take(4))
                {
                    <MatchCard Match="m" />
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private HeroContent? _heroContent;
    private List<Match> _upcomingMatches = new();
    private List<Match> _recentMatches = new();
    private List<NewsArticle> _news = new();
    private List<Standing> _pslStandings = new();
    private List<Player> _topScorers = new();

    protected override async Task OnInitializedAsync()
    {
        _heroContent = await HeroService.GetHeroContentAsync();
        var allMatches = await DataService.GetMatchesAsync();
        _upcomingMatches = allMatches.Where(m => m.Status == "Upcoming").ToList();
        _recentMatches = allMatches.Where(m => m.Status == "Finished").OrderByDescending(m => m.KickoffTime).ToList();
        _news = await DataService.GetNewsAsync();
        _pslStandings = await DataService.GetStandingsAsync("PSL");
        _topScorers = await DataService.GetTopScorersAsync("PSL");
        _loading = false;
    }
}
